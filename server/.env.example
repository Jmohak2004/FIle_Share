# Copy this file to .env and fill in your values.
# Never commit .env to git.

PORT=5001

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/filefight?retryWrites=true&w=majority

# Secret key for JWT signing — use a long random string in production
JWT_SECRET=change_me_to_a_long_random_string

# Your deployed Vercel client URL (no trailing slash)
CLIENT_URL=https://your-app.vercel.app

# Where uploaded files are stored (relative or absolute path)
# On Render paid plan, set to your persistent disk mount path
UPLOADS_DIR=uploads

# SMTP for email notifications (optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
